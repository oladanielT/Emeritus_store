# Paystack Configuration
# Get these keys from your Paystack dashboard at https://dashboard.paystack.com/settings/developers

# Public key - used for client-side Paystack initialization
NEXT_PUBLIC_PAYSTACK_KEY=pk_live_your_public_key_here

# Secret key - used for server-side verification (keep this secret!)
PAYSTACK_SECRET_KEY=sk_live_your_secret_key_here

# Development mode (optional, uncomment for testing)
# PAYSTACK_MODE=test
# NEXT_PUBLIC_PAYSTACK_KEY=pk_test_your_test_public_key
# PAYSTACK_SECRET_KEY=sk_test_your_test_secret_key

# Application URL (for webhooks)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Email Configuration (optional, for order confirmations)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your_email@example.com
# SMTP_PASSWORD=your_password

# Database (when connected)
# DATABASE_URL=your_database_url

# Supabase homepage content repository
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# Use the publishable key from Supabase Project Settings > API.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key
# Server-only. Never expose this value with a NEXT_PUBLIC_ prefix.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Other configurations
NODE_ENV=development
